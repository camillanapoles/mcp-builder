/**
 * {{name}} — MCP server (TypeScript SDK / stateless pattern)
 *
 * {{description}}
 *
 * Generated by mcp-builder. Each tool is a pure function — same input always
 * produces same output, no side effects, no shared state.
 */

import { Server } from '@modelcontextprotocol/sdk/server/index.js';
import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';
import {
  CallToolRequestSchema,
  ListToolsRequestSchema,
} from '@modelcontextprotocol/sdk/types.js';
import { z } from 'zod';

// ============================================================================
// Tool definitions
// ============================================================================

{{#each tools}}
const {{camelCase name}}InputSchema = z.object({
  // TODO: declare input fields for {{name}}
});

const {{camelCase name}}InputJsonSchema = {
  type: 'object' as const,
  properties: {},
  description: '{{description}}',
};

async function {{camelCase name}}(input: z.infer<typeof {{camelCase name}}InputSchema>): Promise<string> {
  // TODO: implement {{name}}
  return '{{name}} executed';
}
{{/each}}

{{#unless tools}}
const helloInputSchema = z.object({
  name: z.string().default('world'),
});

const helloInputJsonSchema = {
  type: 'object' as const,
  properties: {
    name: { type: 'string', description: 'Name to greet' },
  },
};

async function hello(input: z.infer<typeof helloInputSchema>): Promise<string> {
  return `Hello, ${input.name}!`;
}
{{/unless}}

// ============================================================================
// MCP server setup
// ============================================================================

const server = new Server(
  { name: '{{name}}', version: '0.1.0' },
  { capabilities: { tools: {} } },
);

server.setRequestHandler(ListToolsRequestSchema, async () => ({
  tools: [
    {{#each tools}}
    {
      name: '{{name}}',
      description: '{{description}}',
      inputSchema: {{camelCase name}}InputJsonSchema,
    },
    {{/each}}
    {{#unless tools}}
    {
      name: 'hello',
      description: 'Default greeting tool',
      inputSchema: helloInputJsonSchema,
    },
    {{/unless}}
  ],
}));

server.setRequestHandler(CallToolRequestSchema, async (req) => {
  const { name, arguments: args } = req.params;

  try {
    let result: string;

    switch (name) {
      {{#each tools}}
      case '{{name}}': {
        const input = {{camelCase name}}InputSchema.parse(args ?? {});
        result = await {{camelCase name}}(input);
        break;
      }
      {{/each}}
      {{#unless tools}}
      case 'hello': {
        const input = helloInputSchema.parse(args ?? {});
        result = await hello(input);
        break;
      }
      {{/unless}}
      default:
        throw new Error(`unknown tool: ${name}`);
    }

    return {
      content: [{ type: 'text', text: result }],
    };
  } catch (err) {
    return {
      content: [{ type: 'text', text: `error: ${(err as Error).message}` }],
      isError: true,
    };
  }
});

// ============================================================================
// Entry point
// ============================================================================

async function main(): Promise<void> {
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error('[{{name}}] MCP server started (stateless)');
}

main().catch((err) => {
  console.error('fatal:', err);
  process.exit(1);
});
