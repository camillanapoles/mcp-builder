"""Projection store — read models derived from the event log.

For dev: in-memory dict. Production: replace with SQLite/Postgres/Redis.
"""

from __future__ import annotations

from typing import Any


class ProjectionStore:
    """In-memory projection store."""

    def __init__(self) -> None:
        self._data: dict[str, dict[str, Any]] = {}

    def upsert(self, collection: str, doc: dict[str, Any]) -> None:
        cid = collection
        if cid not in self._data:
            self._data[cid] = {}
        # use 'id' as key if present, else auto-increment
        key = doc.get("id", str(len(self._data[cid]) + 1))
        self._data[cid][key] = doc

    def get(self, collection: str, key: str) -> dict[str, Any] | None:
        return self._data.get(collection, {}).get(key)

    def list(self, collection: str) -> list[dict[str, Any]]:
        return list(self._data.get(collection, {}).values())

    def clear(self) -> None:
        self._data.clear()


store = ProjectionStore()
