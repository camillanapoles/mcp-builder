"""Event bus — pub/sub for {{name}}.

Events are Pydantic models. Handlers subscribe to event types.
All events are persisted to an event log (append-only) for replay.
"""

from __future__ import annotations

import asyncio
import json
from datetime import datetime, timezone
from typing import Any, Callable, Type
from collections import defaultdict

from pydantic import BaseModel, Field


class Event(BaseModel):
    """Base event. All events have type, timestamp, payload."""
    type: str
    timestamp: datetime = Field(default_factory=lambda: datetime.now(timezone.utc))
    payload: dict[str, Any] = Field(default_factory=dict)


type EventHandler = Callable[[Event], Any]


class EventBus:
    """In-memory event bus. Production: replace with Redis/Kafka/NATS."""

    def __init__(self) -> None:
        self._handlers: dict[str, list[EventHandler]] = defaultdict(list)
        self._log: list[Event] = []

    def subscribe(self, event_type: str, handler: EventHandler) -> None:
        self._handlers[event_type].append(handler)

    async def publish(self, event: Event) -> None:
        self._log.append(event)  # append-only log
        for handler in self._handlers.get(event.type, []):
            result = handler(event)
            if asyncio.iscoroutine(result):
                await result

    def replay(self) -> list[Event]:
        """Return full event log for replay/debugging."""
        return list(self._log)


# Singleton bus
bus = EventBus()
