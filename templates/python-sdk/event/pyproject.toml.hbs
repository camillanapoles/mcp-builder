[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{name}}"
version = "0.1.0"
description = "{{description}}"
requires-python = ">=3.10"
dependencies = [
    "mcp[cli]>=1.0.0",
    "pydantic>=2.0.0",
    "anyio>=4.0.0",
    "cloudevents>=1.10.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=5.0.0",
    "hypothesis>=6.100.0",
    "mutmut>=3.0.0",
    "ruff>=0.5.0",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{snakeCase name}}"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-v --cov={{snakeCase name}} --cov-report=term-missing --cov-fail-under=80"
