"""Object registry — tracks all objects created by factories.

In-memory for dev. Production: SQLite/Postgres with versioned snapshots.
"""

from __future__ import annotations

from typing import Any
from collections import defaultdict


class Registry:
    """Type-indexed registry of created objects."""

    def __init__(self) -> None:
        self._objects: dict[str, dict[str, Any]] = defaultdict(dict)

    def register(self, type_: str, id_: str, obj: Any) -> None:
        self._objects[type_][id_] = obj

    def get(self, type_: str, id_: str) -> Any | None:
        return self._objects.get(type_, {}).get(id_)

    def list(self, type_: str) -> list[Any]:
        return list(self._objects.get(type_, {}).values())

    def remove(self, type_: str, id_: str) -> bool:
        return self._objects.get(type_, {}).pop(id_, None) is not None

    def clear(self) -> None:
        self._objects.clear()


registry = Registry()
