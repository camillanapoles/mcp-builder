"""{{name}} — MCP server entry point.

Stateless execution pattern: each tool call is independent, deterministic,
side-effect-free (when possible). State machine lives in .mcp/state/.
"""

from __future__ import annotations

import logging
from typing import Any

from .app import mcp
from . import tools  # noqa: F401 — triggers @mcp.tool() registration
from .resources import register_resources

logger = logging.getLogger("{{name}}")

# Register MCP resources
register_resources(mcp)


def main() -> None:
    """Run the MCP server over stdio."""
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    )
    logger.info("starting {{name}} MCP server (stateless)")
    mcp.run()


if __name__ == "__main__":
    main()
