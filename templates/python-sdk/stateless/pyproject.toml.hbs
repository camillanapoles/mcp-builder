[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{name}}"
version = "0.1.0"
description = "{{description}}"
readme = "README.md"
requires-python = ">=3.10"
license = { text = "{{#if metadata.license}}{{metadata.license}}{{else}}MIT{{/if}}" }
authors = [
    { name = "{{#if metadata.author}}{{metadata.author}}{{else}}mcp-builder{{/if}}" }
]
keywords = ["mcp", "model-context-protocol", {{#each metadata.keywords}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
dependencies = [
    "mcp[cli]>=1.0.0",
    "pydantic>=2.0.0",
    "anyio>=4.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=5.0.0",
    "pytest-asyncio>=0.23.0",
    "mutmut>=3.0.0",
    "hypothesis>=6.100.0",
    "pact-python>=2.0.0",
    "ruff>=0.5.0",
    "mypy>=1.10.0",
]

[project.scripts]
{{name}} = "{{snakeCase name}}.server:main"

[tool.hatch.build.targets.wheel]
packages = ["src/{{snakeCase name}}"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-v --cov={{snakeCase name}} --cov-report=term-missing --cov-fail-under=80"
asyncio_mode = "auto"

[tool.ruff]
line-length = 100
target-version = "py310"

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP", "B", "ASYNC"]

[tool.mypy]
python_version = "3.10"
strict = true

[tool.mutmut]
paths_to_mutate = ["src/{{snakeCase name}}"]
tests_dir = ["tests/"]
runner = "python -m pytest -x -q"
