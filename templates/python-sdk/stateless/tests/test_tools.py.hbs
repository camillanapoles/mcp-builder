# ============================================================================
# Per-tool tests — one block per tool declared in spec
# ============================================================================

{{#each tools}}
class Test{{pascalCase name}}:
    """Tests for `{{name}}` tool."""

    def test_{{name}}_returns_string(self):
        """{{name}} must return a string (MCP text content)."""
        from {{../name}}.tools import {{name}}
        result = {{name}}()
        assert isinstance(result, str)

    def test_{{name}}_deterministic(self):
        """Same input → same output (stateless invariant)."""
        from {{../name}}.tools import {{name}}
        r1 = {{name}}()
        r2 = {{name}}()
        assert r1 == r2

    def test_{{name}}_no_side_effects(self):
        """Tool must not mutate global state."""
        from {{../name}}.tools import {{name}}
        import {{../name}}.tools as tools_mod
        before = dict(vars(tools_mod))
        {{name}}()
        after = dict(vars(tools_mod))
        # ignore return value of {{name}} itself
        before.pop("{{name}}", None)
        after.pop("{{name}}", None)
        assert before.keys() == after.keys()

{{/each}}

{{#unless tools}}
class TestDefaultHello:
    """Tests for default hello tool."""

    def test_hello_default(self):
        from {{snakeCase name}}.tools import hello
        assert hello() == "Hello, world!"

    def test_hello_with_name(self):
        from {{snakeCase name}}.tools import hello
        assert hello("agent") == "Hello, agent!"

    def test_hello_deterministic(self):
        from {{snakeCase name}}.tools import hello
        assert hello("x") == hello("x")
{{/unless}}
