{
  "name": "@mcp-builder/cli",
  "version": "1.0.0",
  "description": "MCP Builder — generates, validates and operates MCP servers with GitOps determinism",
  "type": "module",
  "bin": {
    "mcp-builder": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "serve": "node dist/mcp/server.js",
    "serve:http": "node dist/http/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run --config vitest.property.config.ts",
    "test:mutation": "stryker run",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/cache": "^3.2.4",
    "@actions/artifact": "^2.1.1",
    "commander": "^12.1.0",
    "fastify": "^4.28.1",
    "@fastify/cors": "^10.0.0",
    "handlebars": "^4.7.8",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.5.0",
    "fast-check": "^3.19.0",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.5",
    "vitest": "^2.0.5",
    "@stryker-mutator/core": "^8.5.0",
    "@stryker-mutator/vitest-runner": "^8.5.0",
    "@types/node": "^22.5.0",
    "eslint": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ]
}
