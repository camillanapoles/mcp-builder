{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "coverageAnalysis": "off",
  "mutate": [
    "src/validator/index.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "reporters": ["clear-text", "html"],
  "concurrency": 1,
  "ignorePatterns": ["dist/**", "node_modules/**"]
}
